MONGODB_URI="mongodb+srv://..."
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_S3_REGION=""

# Live recording service — runs as part of the Fly streaming app
# Local dev:   RECORDER_URL=http://localhost:8080   (docker-compose up in ops/streaming)
# Production:  RECORDER_URL=https://missionnaire-streaming-app.fly.dev:8443
RECORDER_URL=""
RECORDER_TOKEN=""

# Icecast /status-json.xsl endpoint (used for the "live but not recording" banner)
# Local dev:   defaults to http://localhost:8000/status-json.xsl
# Production:  https://missionnaire-streaming-app.fly.dev/status-json.xsl
# ICECAST_STATUS_URL=""

# Icecast public MP3 URL (used for the admin live-audio monitor).
# If unset, derived automatically by replacing /status-json.xsl → /radio.mp3.
# ICECAST_STREAM_URL="https://missionnaire-streaming-app.fly.dev/radio.mp3"

# Main site URL — used by the Go Live action to trigger the push notification
# immediately (without it, the push fires only when a visitor next polls /live).
# Production: https://missionnaire.net
# Local dev:  http://localhost:5174 (or wherever the main site dev server runs)
MAIN_SITE_URL=""

# --- S3 bucket policy required for public playback of the recordings/ prefix ---
# Only this prefix is public-read; music-audio/ stays private.
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Sid": "PublicReadRecordings",
#       "Effect": "Allow",
#       "Principal": "*",
#       "Action": "s3:GetObject",
#       "Resource": "arn:aws:s3:::<bucket>/recordings/*"
#     }
#   ]
# }
