{
	"name": "missionaire-web",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"stream:up": "docker compose -f ops/streaming/docker-compose.yml up -d --build",
		"stream:down": "docker compose -f ops/streaming/docker-compose.yml down",
		"stream:logs": "docker compose -f ops/streaming/docker-compose.yml logs -f --tail=100"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.3.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-vercel": "^5.10.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@types/node": "^25.0.3",
		"@types/web-push": "^3.6.4",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"autoprefixer": "^10.4.20",
		"chalk": "^5.3.0",
		"debug": "^4.3.4",
		"eslint": "^8.47.0",
		"eslint-config-prettier": "^8.10.0",
		"eslint-plugin-svelte": "^2.46",
		"iconsax-svelte": "0.0.1-alpha.11",
		"minimist": "^1.2.8",
		"node-fetch": "^3.3.2",
		"postcss": "^8.4.49",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.6.2",
		"typescript": "^5.5",
		"vite": "^6.4.1",
		"vitest": "^2.1.9"
	},
	"type": "module",
	"dependencies": {
		"@badrap/result": "^0.2.13",
		"@distube/ytdl-core": "^4.16.12",
		"@googlemaps/js-api-loader": "^1.16.2",
		"@tanstack/svelte-query": "^5.35.1",
		"flowbite-svelte": "^0.44.20",
		"mongodb": "^6.8.0",
		"plyr": "^3.7.8",
		"svelte-icons-pack": "^2.1.0",
		"web-push": "^3.6.7",
		"zod": "^3.22.2"
	}
}
